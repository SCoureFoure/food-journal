# .env (repo root) — developer machine only. Gitignored. Never bundled into the app.
# Used by: integration tests via test_env.dart
#   (reads Platform.environment first, then falls back to this file)
# Used by: Cloudflare Worker deployment scripts

# Which AI provider the app uses (informational — actual routing is in code)
AI_PROVIDER=worker

# Cloudflare Worker endpoint (same as app/.env — duplicated here for test scripts)
MEAL_PARSER_URL=https://your-worker.workers.dev

# Anthropic Claude API key — used by integration tests only.
# NOT used by the Flutter app at runtime. Never put this in app/.env.
ANTHROPIC_API_KEY=sk-ant-...

# Gemini API key — used by the Cloudflare Worker backend (server-side only).
GEMINI_API_KEY_PAID=your-gemini-key

# Cloudflare account token — for Worker deployment/management.
CLOUDFLARE_API_TOKEN=your-cloudflare-token

# Auth token passed in test requests to the Worker.
TEST_AUTH_TOKEN=your-test-token
