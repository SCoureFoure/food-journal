# app/.env — bundled into the Flutter app binary via flutter_dotenv.
# This file is included in the APK/IPA as a plain-text asset.
# DO NOT put API keys or secrets here — they will be readable by anyone
# who decompiles the app.

# URL of the Cloudflare Worker that handles AI meal/medication parsing.
# The Worker holds its own Gemini key server-side; this is just an endpoint URL.
MEAL_PARSER_URL=https://your-worker.workers.dev

# Minutes to wait before firing the post-entry check-in notification.
CHECKIN_DELAY_MINUTES=90
